{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"resources/**/*.{js,css}\" \"public/assets/**/*.{js,css}\"",
        "format:check": "prettier --check \"resources/**/*.{js,css}\" \"public/assets/**/*.{js,css}\"",
        "lint": "eslint resources/js public/assets/js",
        "lint:fix": "eslint resources/js public/assets/js --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "laravel-vite-plugin": "^3.1.0",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
